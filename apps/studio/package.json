{
	"name": "@a3s-lab/studio",
	"private": true,
	"version": "0.1.0",
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"postinstall": "pnpm -C sidecar install && pnpm -C sidecar build:packages && pnpm prepare:sidecar",
		"clean": "rimraf dist && rimraf node_modules",
		"dev": "rsbuild dev --env-dir ./env",
		"dev:all": "concurrently -n \"sidecar,tauri\" -c \"magenta,cyan\" \"pnpm dev:sidecar\" \"pnpm tauri:dev\"",
		"dev:sidecar": "pnpm -C sidecar/api start:dev",
		"build": "rsbuild build --env-dir ./env",
		"preview": "rsbuild preview --env-dir ./env",
		"tauri": "tauri",
		"tauri:dev": "tauri dev",
		"tauri:build": "pnpm build:sidecar && tauri build",
		"build:sidecar": "pnpm -C sidecar/api build:sea",
		"prepare:sidecar": "node scripts/prepare-sidecar.mjs",
		"format": "pnpm biome format --write ."
	},
	"dependencies": {
		"@radix-ui/react-alert-dialog": "^1.1.2",
		"@radix-ui/react-avatar": "^1.1.1",
		"@radix-ui/react-dialog": "^1.1.2",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-label": "^2.1.0",
		"@radix-ui/react-scroll-area": "^1.2.0",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-separator": "^1.1.0",
		"@radix-ui/react-slot": "^1.1.0",
		"@radix-ui/react-switch": "^1.1.1",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-tooltip": "^1.1.3",
		"@tauri-apps/api": "^2",
		"@tauri-apps/plugin-http": "^2",
		"@tauri-apps/plugin-shell": "^2",
		"ahooks": "^3.8.1",
		"class-variance-authority": "^0.7.0",
		"clsx": "^2.1.1",
		"dayjs": "^1.11.13",
		"keepalive-for-react": "^3.0.3",
		"lucide-react": "^0.453.0",
		"motion": "^12.9.4",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-router-dom": "^7.5.3",
		"sonner": "^2.0.7",
		"tailwind-merge": "^2.5.4",
		"tailwind-variants": "^0.2.1",
		"valtio": "^2.1.1"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.3",
		"@rsbuild/core": "^1.0.15",
		"@rsbuild/plugin-less": "^1.2.2",
		"@rsbuild/plugin-react": "^1.0.5",
		"@rsbuild/plugin-sass": "^1.5.0",
		"@tailwindcss/typography": "^0.5.15",
		"@tauri-apps/cli": "^2",
		"@types/node": "^22.7.9",
		"@types/react": "^19.1.3",
		"@types/react-dom": "^18.3.1",
		"autoprefixer": "^10.4.20",
		"cssnano": "^7.0.7",
		"postcss": "^8.4.47",
		"concurrently": "^9.0.0",
		"rimraf": "^6.0.1",
		"tailwindcss": "^3.4.14",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^5.6.3"
	}
}
