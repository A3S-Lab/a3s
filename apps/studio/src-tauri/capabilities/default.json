{
	"$schema": "https://raw.githubusercontent.com/nicegui-dev/nicegui-tauri/main/capability_schema.json",
	"identifier": "default",
	"description": "Default capabilities for Studio",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"shell:allow-open",
		"shell:allow-spawn",
		"shell:allow-execute",
		"http:default",
		{
			"identifier": "http:default",
			"allow": [
				{ "url": "http://127.0.0.1:3000/**" }
			]
		}
	]
}
