{
	"$schema": "https://raw.githubusercontent.com/nicegui-dev/nicegui-tauri/main/capability_schema.json",
	"identifier": "default",
	"description": "Default capabilities for SafeClaw",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"shell:allow-open",
		"http:default",
		"dialog:default",
		"core:webview:allow-create-webview-window",
		{
			"identifier": "http:default",
			"allow": [
				{ "url": "http://127.0.0.1:18790/**" },
				{ "url": "http://127.0.0.1:11435/**" }
			]
		}
	]
}
